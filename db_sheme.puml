@startuml

hide circle
skinparam linetype ortho
skinparam nodesep 90
skinparam ranksep 50

entity User {
  *id : Integer <<generated>>
  --
  telegram_id : BigInteger <<unique>>
  username : String
  first_name : String
  is_admin : Boolean
  created_at : DateTime
}

entity Lesson {
  *id : Integer <<generated>>
  --
  title : String
  description : Text
  content : Text
  is_published : Boolean
  created_at : DateTime
}

entity Submission {
  *id : Integer <<generated>>
  --
  user_id : Integer <<FK>>
  lesson_id : Integer <<FK>>

  answer : Text
  status : String
  score : Integer

  submitted_at : DateTime
  reviewed_at : DateTime
}

entity UserProgress {
  *id : Integer <<generated>>
  --
  user_id : Integer <<FK>>
  lesson_id : Integer <<FK>>

  is_completed : Boolean
  completed_at : DateTime
}

entity ActionLog {
  *id : Integer <<generated>>
  --
  user_id : Integer <<FK>>

  action : String
  details : Text

  created_at : DateTime
}

User ||--o{ Submission
Lesson ||--o{ Submission

User ||--o{ UserProgress
Lesson ||--o{ UserProgress

User ||--o{ ActionLog

@enduml