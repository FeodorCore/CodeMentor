@startuml
skinparam backgroundColor #FFFFFF
skinparam activity {
    BackgroundColor<<learn>> #E3F2FD
    BorderColor<<learn>> #1976D2
    BackgroundColor<<test>> #FFF3E0
    BorderColor<<test>> #F57C00
    BackgroundColor<<ai>> #F3E5F5
    BorderColor<<ai>> #7B1FA2
    BackgroundColor<<admin>> #E8F5E9
    BorderColor<<admin>> #388E3C
    RoundCorner 10
    FontSize 12
}
skinparam dpi 150
skinparam shadowing false

start

:📱 Запуск бота /start;

:📂 Выбор категории курса;

:📖 Получение урока\n(теория + примеры кода); <<learn>>

:👀 Изучение материала;

:✅ Нажатие "Ознакомился";

:📝 Тестирование\n(1 вопрос на урок); <<test>>

if (Ответ правильный?) then (✅ Да)
  :🎉 Прогресс обновлён;
  :➡️ Переход к следующему уроку;
else (❌ Нет)
  :📉 Ошибка сохранена в БД;
  :🤖 Обращение к ИИ-наставнику; <<ai>>
  :💬 ИИ разбирает ошибку\nдаёт пояснение по теме;
  :🔄 Возможность продолжить\nили повторить материал;
endif

:--- Административная часть ---;

:🌐 Вход в Web-панель; <<admin>>
:📊 Просмотр прогресса учеников\n(статистика, ответы, ошибки);
:✏️ Управление курсами\n(категории, уроки, тесты);

stop
@enduml